---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const works = await getCollection('works');
  return works.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, pubDate, thumbnail, tags, links } = entry.data;

const linkMeta: Record<string, { label: string; badge: string }> = {
  github:  { label: 'GitHub',      badge: 'GH'  },
  demo:    { label: 'Live Demo',   badge: '▶'   },
  article: { label: 'Article',     badge: '✏'   },
  other:   { label: 'Link',        badge: '↗'   },
};
---

<PostLayout
  title={title}
  description={description}
  pubDate={pubDate}
  backHref="/#works"
>
  <div slot="meta" class="worksMeta">

    <!-- Thumbnail -->
    <div class="thumbnailWrap">
      <Image src={thumbnail} alt={`${title} thumbnail`} class="thumbnail" />
    </div>

    <!-- Tech stack tags -->
    {
      tags.length > 0 && (
        <div class="stackSection">
          <span class="stackLabel">TECH STACK</span>
          <ul class="tagList" aria-label="技術スタック">
            {tags.map((tag) => (
              <li class="tag">{tag}</li>
            ))}
          </ul>
        </div>
      )
    }

    <!-- Links -->
    {
      links && links.length > 0 && (
        <div class="linkButtons">
          {links.map((link) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class={`linkBtn linkBtn--${link.type}`}
            >
              <span class="linkBadge">{linkMeta[link.type].badge}</span>
              <span class="linkLabel">{linkMeta[link.type].label}</span>
            </a>
          ))}
        </div>
      )
    }
  </div>

  <Content />
</PostLayout>

<style>
  .worksMeta {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* ── Thumbnail ── */
  .thumbnailWrap {
    width: 100%;
    aspect-ratio: 16 / 7;
    overflow: hidden;
    border: 2px solid rgba(204, 255, 0, 0.22);
    background: rgba(204, 255, 0, 0.03);
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .thumbnailWrap::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 55%,
      var(--color-bg) 100%
    );
    pointer-events: none;
  }

  .thumbnail {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    transition: transform 0.6s var(--ease-elastic);
  }

  .thumbnailWrap:hover .thumbnail {
    transform: scale(1.04);
  }

  /* ── Tech stack ── */
  .stackSection {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .stackLabel {
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.2em;
    color: rgba(248, 250, 252, 0.35);
    text-transform: uppercase;
  }

  .tagList {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
  }

  .tag {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
    border: 1.5px solid var(--color-accent);
    color: var(--color-accent);
    cursor: default;
    transition:
      transform 0.2s var(--ease-elastic),
      background 0.2s,
      color 0.2s;
  }

  .tag:nth-child(3n+1) { transform: rotate(-1.2deg); }
  .tag:nth-child(3n+2) { transform: rotate(0.8deg);  }
  .tag:nth-child(3n)   { transform: rotate(-0.4deg); }

  .tag:hover {
    transform: rotate(0deg) scale(1.12) !important;
    background: var(--color-accent);
    color: var(--color-bg);
  }

  /* ── Link buttons ── */
  .linkButtons {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .linkBtn {
    --btn-color: var(--color-primary);
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.8rem 1.6rem;
    text-decoration: none;
    font-weight: 900;
    font-size: 0.82rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border: 2px solid var(--btn-color);
    color: var(--btn-color);
    position: relative;
    transition:
      transform 0.2s var(--ease-elastic),
      box-shadow 0.2s,
      background 0.2s,
      color 0.2s;
  }

  .linkBtn--github  { --btn-color: var(--color-primary); }
  .linkBtn--demo    { --btn-color: var(--color-secondary); }
  .linkBtn--article { --btn-color: var(--color-accent); }
  .linkBtn--other   { --btn-color: var(--color-text); }

  .linkBtn:hover {
    background: var(--btn-color);
    color: var(--color-bg);
    transform: translate(-4px, -4px) rotate(-1deg);
    box-shadow: 6px 6px 0 var(--btn-color);
  }

  .linkBadge {
    font-size: 0.75rem;
    line-height: 1;
  }

  @media (max-width: 560px) {
    .linkButtons {
      flex-direction: column;
    }

    .linkBtn {
      justify-content: center;
    }
  }
</style>
