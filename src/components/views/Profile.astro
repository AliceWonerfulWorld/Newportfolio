---
// src/components/views/Profile.astro
---

<section class="profileSection" id="profile" aria-label="Profile & Vision">

  <!-- ── Section header ──────────────────────────────────────── -->
  <div class="profileHeader">
    <p class="headerEyebrow">&gt; 02_PROFILE &amp; VISION</p>
    <h2 class="headerTitle">
      <span class="headerLine">ABOUT</span>
      <span class="headerLine headerLineAccent">ME.</span>
    </h2>
    <p class="headerLead">
      福岡工業大学情報工学科から、ウイングアーク1stへ。<br/>
      コードに遊び心を、社会に本物の価値を。
    </p>
  </div>

  <!-- ═══════════════════════════════════════════════════════════
       Chapter 01 — VISION
       keyword fills neon-yellow as user scrolls into chapter
  ═══════════════════════════════════════════════════════════ -->
  <div class="profileChapter" data-profile-chapter>
    <div class="chapterSticky chapterSticky--vision" data-chapter-sticky>

      <!-- Huge background keyword (ink-fill effect) -->
      <div class="keywordWrapper kwWrap--right" aria-hidden="true">
        <span class="keywordBase">VISION</span>
        <span class="keywordFill kFill--primary" data-keyword-fill>VISION</span>
      </div>

      <!-- Content block -->
      <div class="chapterContent ccLeft" data-profile-text>
        <p class="chapterNum">01</p>
        <h3 class="chapterHeading">
          夢と挑戦の<br/>
          <em>ステージへ</em>
        </h3>
        <div class="chapterBody">
          <p>
            福岡工業大学情報工学科での4年間、アルゴリズム・OS・ネットワークの
            基礎理論から実装まで幅広く学んだ。ハッカソンという「本番」を繰り返す
            なかで磨いた、限られた時間で動くものを作り切る力。
          </p>
          <p>
            次のステージは <strong class="accentText">ウイングアーク1st</strong>
            での開発エンジニア。大学で問い続けた「なぜ？」を、
            社会が求める「どう作る？」へと昇華させる。
          </p>
        </div>
        <blockquote class="chapterQuote quoteVision" data-profile-text>
          &ldquo;ゲームを作る感覚で、<br/>
          社会に届くソフトウェアを。&rdquo;
        </blockquote>
      </div>

    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════
       Chapter 02 — SKILLS
       keyword fills cyan
  ═══════════════════════════════════════════════════════════ -->
  <div class="profileChapter" data-profile-chapter>
    <div class="chapterSticky chapterSticky--skills" data-chapter-sticky>

      <div class="keywordWrapper kwWrap--left" aria-hidden="true">
        <span class="keywordBase">SKILLS</span>
        <span class="keywordFill kFill--accent" data-keyword-fill>SKILLS</span>
      </div>

      <div class="chapterContent ccRight" data-profile-text>
        <p class="chapterNum">02</p>
        <h3 class="chapterHeading">
          コードで考える<br/>
          <em>言語たち</em>
        </h3>
        <ul class="skillTimeline">
          <li class="skillItem" data-profile-text>
            <span class="skillYear">2021</span>
            <span class="skillDot"></span>
            <div class="skillInfo">
              <span class="skillName">C / C++</span>
              <span class="skillNote">アルゴリズム・OS・メモリ管理</span>
            </div>
          </li>
          <li class="skillItem" data-profile-text>
            <span class="skillYear">2022</span>
            <span class="skillDot"></span>
            <div class="skillInfo">
              <span class="skillName">Java</span>
              <span class="skillNote">オブジェクト指向・デザインパターン</span>
            </div>
          </li>
          <li class="skillItem" data-profile-text>
            <span class="skillYear">2023</span>
            <span class="skillDot"></span>
            <div class="skillInfo">
              <span class="skillName">Python</span>
              <span class="skillNote">データ処理・AI/ML入門</span>
            </div>
          </li>
          <li class="skillItem" data-profile-text>
            <span class="skillYear">2024</span>
            <span class="skillDot skillDot--hot"></span>
            <div class="skillInfo">
              <span class="skillName">TypeScript / React</span>
              <span class="skillNote">フロントエンド・Webアプリ開発</span>
            </div>
          </li>
          <li class="skillItem" data-profile-text>
            <span class="skillYear">+</span>
            <span class="skillDot skillDot--glow"></span>
            <div class="skillInfo">
              <span class="skillName">WebAR · GSAP · Three.js</span>
              <span class="skillNote">没入型インタラクション体験の創造</span>
            </div>
          </li>
        </ul>
        <blockquote class="chapterQuote quoteSkills" data-profile-text>
          &ldquo;言語はツール。大切なのは、<br/>
          問題の本質を見抜く力。&rdquo;
        </blockquote>
      </div>

    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════
       Chapter 03 — ETHICS
       keyword fills neon-pink, centered
  ═══════════════════════════════════════════════════════════ -->
  <div class="profileChapter" data-profile-chapter>
    <div class="chapterSticky chapterSticky--ethics" data-chapter-sticky>

      <div class="keywordWrapper kwWrap--center" aria-hidden="true">
        <span class="keywordBase">ETHICS</span>
        <span class="keywordFill kFill--secondary" data-keyword-fill>ETHICS</span>
      </div>

      <div class="chapterContent ccCenter" data-profile-text>
        <p class="chapterNum">03</p>
        <h3 class="chapterHeading">
          遊び心と、<br/>
          <em>責任感を。</em>
        </h3>
        <div class="chapterBody">
          <p>
            情報技術は、使い方次第で社会を変える力を持つ。
            その力を扱う者として、プライバシー・セキュリティ・
            アクセシビリティへの深い配慮を忘れない。
          </p>
          <p>
            同時に、技術そのものへの「遊び心」を決して手放さない。
            真剣にふざけること、それが最高のプロダクトへの近道だと信じている。
          </p>
        </div>
        <blockquote class="chapterQuote quoteEthics" data-profile-text>
          &ldquo;真剣に、遊ぶ。&rdquo;
        </blockquote>
      </div>

    </div>
  </div>

</section>

<script>
  import { animateProfileSticky } from '../../utils/animations';

  const section = document.getElementById('profile');
  if (section) animateProfileSticky(section);
</script>

<style>
  /* ── Section shell ──────────────────────────────────────────── */
  .profileSection {
    background: var(--color-bg);
    overflow: hidden; /* clip decorative overflow only on section level */
  }

  /* ── Section header ─────────────────────────────────────────── */
  .profileHeader {
    padding: 10vh 6vw 8vh;
    position: relative;
  }

  .profileHeader::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 6vw;
    width: 120px;
    height: 4px;
    background: var(--grad-ink);
  }

  .headerEyebrow {
    font-family: 'Courier New', monospace;
    font-size: clamp(0.75rem, 1.5vw, 1rem);
    color: var(--color-accent);
    letter-spacing: 0.12em;
    margin: 0 0 0.75rem;
    opacity: 0.8;
  }

  .headerTitle {
    display: flex;
    flex-direction: column;
    font-size: clamp(4.5rem, 12vw, 9rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    line-height: 0.88;
    margin: 0 0 2rem;
    transform: rotate(-1.5deg);
    transform-origin: left top;
  }

  .headerLine { color: var(--color-text); }

  .headerLineAccent {
    color: var(--color-primary);
    /* Offset position for asymmetry */
    margin-left: 8vw;
    text-shadow:
      4px 4px 0 var(--color-secondary),
      8px 8px 0 rgba(255, 0, 122, 0.3);
  }

  .headerLead {
    font-size: clamp(0.95rem, 1.8vw, 1.2rem);
    color: var(--color-text);
    opacity: 0.65;
    line-height: 1.8;
    max-width: 560px;
    margin: 0;
  }

  /* ── Chapter outer shell (provides scroll distance) ─────────── */
  .profileChapter {
    /* Height set by GSAP pinSpacing — no need to set manually */
  }

  /* ── Sticky container ─────────────────────────────────────────
     GSAP pins this element. Must be 100vh tall so it fills viewport
     exactly while pinned.
  ──────────────────────────────────────────────────────────────── */
  .chapterSticky {
    height: 100vh;
    position: relative; /* containing block for absolute keyword */
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--color-bg);
  }

  /* Subtle noise-like border between chapters */
  .chapterSticky::before {
    content: '';
    position: absolute;
    top: 0;
    left: 6vw;
    right: 6vw;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--color-primary) 20%,
      var(--color-accent) 80%,
      transparent
    );
    opacity: 0.2;
  }

  /* ── Huge keyword (background layer) ────────────────────────── */
  .keywordWrapper {
    position: absolute;
    user-select: none;
    pointer-events: none;
    line-height: 0.85;
    z-index: var(--z-base);
  }

  .keywordBase,
  .keywordFill {
    display: block;
    font-size: clamp(6rem, 18vw, 16rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.04em;
    line-height: 0.85;
    white-space: nowrap;
  }

  .keywordBase {
    color: rgba(248, 250, 252, 0.04);
  }

  /* keywordFill sits exactly over keywordBase */
  .keywordFill {
    position: absolute;
    top: 0;
    left: 0;
    /* clip-path animated by GSAP: inset(100% → 0%) = ink fills bottom-to-top */
    clip-path: inset(100% 0 0 0);
    will-change: clip-path;
  }

  /* Fill colors per chapter */
  .kFill--primary   { color: var(--color-primary); }
  .kFill--accent    { color: var(--color-accent); }
  .kFill--secondary { color: var(--color-secondary); }

  /* ── Keyword positioning per chapter ────────────────────────── */
  .kwWrap--right {
    right: -3vw;
    bottom: 8vh;
  }

  .kwWrap--left {
    left: -2vw;
    top: 12vh;
  }

  .kwWrap--center {
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
  }
  /* center keyword needs both spans to also center */
  .kwWrap--center .keywordBase,
  .kwWrap--center .keywordFill {
    text-align: center;
  }

  /* ── Content block ───────────────────────────────────────────── */
  .chapterContent {
    position: relative;
    z-index: var(--z-ui);
    max-width: 540px;
    padding: 0 6vw;
  }

  /* Left-aligned (Vision) */
  .ccLeft {
    margin-right: auto;
  }

  /* Right-aligned (Skills) */
  .ccRight {
    margin-left: auto;
  }

  /* Centered (Ethics) */
  .ccCenter {
    margin: 0 auto;
    text-align: center;
  }

  /* ── Chapter number ─────────────────────────────────────────── */
  .chapterNum {
    font-family: 'Courier New', monospace;
    font-size: clamp(0.7rem, 1.2vw, 0.9rem);
    letter-spacing: 0.2em;
    color: var(--color-accent);
    margin: 0 0 0.8rem;
    opacity: 0.7;
  }

  /* ── Chapter heading ────────────────────────────────────────── */
  .chapterHeading {
    font-size: clamp(2rem, 5vw, 3.6rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--color-text);
    margin: 0 0 1.8rem;
  }

  .chapterHeading em {
    font-style: normal;
    /* Gradient text on italic/emphasis spans */
    background: var(--grad-ink);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* ── Body text ──────────────────────────────────────────────── */
  .chapterBody {
    margin-bottom: 1.5rem;
  }

  .chapterBody p {
    font-size: clamp(0.9rem, 1.5vw, 1.05rem);
    line-height: 1.85;
    color: var(--color-text);
    opacity: 0.75;
    margin: 0 0 1rem;
  }

  .chapterBody p:last-child { margin-bottom: 0; }

  .accentText {
    color: var(--color-primary);
    font-weight: 700;
  }

  /* ── Quote accent ───────────────────────────────────────────── */
  .chapterQuote {
    font-family: 'Courier New', monospace;
    font-size: clamp(0.85rem, 1.5vw, 1.05rem);
    line-height: 1.7;
    color: var(--color-text);
    opacity: 0.9;
    border-left: 4px solid var(--color-primary);
    padding: 0.6rem 0 0.6rem 1.2rem;
    margin: 1.8rem 0 0;
    quotes: none;
    transform: rotate(-0.5deg);
  }

  .quoteSkills {
    border-left-color: var(--color-accent);
  }

  .quoteEthics {
    border-left-color: var(--color-secondary);
    /* Ethics is centered — adjust quote style */
    border-left: none;
    border-top: 4px solid var(--color-secondary);
    padding: 1rem 0 0;
    font-size: clamp(1rem, 2vw, 1.4rem);
    font-weight: 700;
    letter-spacing: 0.04em;
    transform: none;
  }

  /* ── Skill timeline list ─────────────────────────────────────── */
  .skillTimeline {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .skillItem {
    display: grid;
    grid-template-columns: 3.5rem 16px 1fr;
    align-items: center;
    gap: 0 1rem;
    padding: 0.55rem 0;
    border-bottom: 1px solid rgba(248, 250, 252, 0.08);
  }

  .skillItem:last-child { border-bottom: none; }

  .skillYear {
    font-family: 'Courier New', monospace;
    font-size: 0.72rem;
    color: var(--color-accent);
    letter-spacing: 0.06em;
    opacity: 0.7;
    text-align: right;
    padding-right: 0.2rem;
  }

  /* Vertical dot on the timeline */
  .skillDot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(248, 250, 252, 0.25);
    border: 2px solid rgba(248, 250, 252, 0.3);
    justify-self: center;
  }

  .skillDot--hot {
    background: var(--color-primary);
    border-color: var(--color-primary);
    box-shadow: 0 0 8px var(--color-primary);
  }

  .skillDot--glow {
    background: var(--color-secondary);
    border-color: var(--color-secondary);
    box-shadow: 0 0 12px var(--color-secondary);
    animation: dotPulse 1.8s ease-in-out infinite;
  }

  @keyframes dotPulse {
    0%, 100% { box-shadow: 0 0 8px var(--color-secondary); }
    50%       { box-shadow: 0 0 20px var(--color-secondary), 0 0 40px rgba(255, 0, 122, 0.3); }
  }

  .skillInfo {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .skillName {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: 0.02em;
  }

  .skillNote {
    font-family: 'Courier New', monospace;
    font-size: 0.72rem;
    color: var(--color-text);
    opacity: 0.45;
    letter-spacing: 0.04em;
  }

  /* ── Chapter-specific backgrounds (subtle) ──────────────────── */
  .chapterSticky--skills {
    /* Barely-visible diagonal stripe for variety */
    background-image: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 60px,
      rgba(0, 240, 255, 0.015) 60px,
      rgba(0, 240, 255, 0.015) 61px
    );
  }

  .chapterSticky--ethics {
    background-image: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 80px,
      rgba(255, 0, 122, 0.015) 80px,
      rgba(255, 0, 122, 0.015) 81px
    );
  }

  /* ── Responsive ─────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .keywordBase,
    .keywordFill {
      font-size: clamp(4rem, 22vw, 7rem);
    }

    .kwWrap--right {
      right: -5vw;
      bottom: auto;
      top: 4vh;
    }

    .kwWrap--left {
      left: -3vw;
      top: 4vh;
    }

    .chapterContent {
      padding: 0 5vw;
    }

    .ccRight {
      margin-left: 0;
    }

    .ccCenter {
      text-align: left;
    }

    .quoteEthics {
      border-top: none;
      border-left: 4px solid var(--color-secondary);
      padding: 0.6rem 0 0.6rem 1.2rem;
      text-align: left;
    }

    .skillTimeline {
      gap: 0;
    }
  }
</style>
