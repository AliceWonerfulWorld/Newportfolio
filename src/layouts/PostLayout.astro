---
// src/layouts/PostLayout.astro
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import CustomCursor from '../components/islands/CustomCursor';

interface Props {
  title: string;
  description: string;
  pubDate?: Date;
  backHref?: string;
}

const { title, description, pubDate, backHref = '/' } = Astro.props;
const formattedDate = pubDate
  ? pubDate.toLocaleDateString('ja-JP', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <title>{title} | Portfolio</title>
    <!-- View Transitions router -->
    <ClientRouter />
  </head>
  <body>
    <!-- カスタムカーソル: transition:persist で全遷移を通じて生存 -->
    <CustomCursor client:only="react" transition:persist />

    <a href={backHref} class="backLink" aria-label="戻る">
      <span class="backArrow">←</span>
      <span class="backText">BACK</span>
    </a>

    <article class="postContainer">
      <header class="postHeader">
        <div class="titleDecor" aria-hidden="true">
          <span class="inkBlob"></span>
          <span class="inkDot"></span>
        </div>
        <h1 class="postTitle" data-post-title>{title}</h1>
        {
          formattedDate && (
            <time
              class="postDate"
              data-post-meta
              datetime={pubDate?.toISOString()}
            >
              {formattedDate}
            </time>
          )
        }
      </header>

      <div class="metaSection" data-post-meta>
        <slot name="meta" />
      </div>

      <div class="prose" data-post-content>
        <slot />
      </div>
    </article>

    <!-- GSAP CDN -->
    <script
      src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"
      is:inline
    ></script>
    <script
      src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"
      is:inline
    ></script>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', function () {
        if (typeof gsap === 'undefined') return;

        var tl = gsap.timeline({ defaults: { ease: 'power4.out' } });

        tl.from('[data-post-title]', {
          opacity: 0,
          y: 90,
          skewY: -4,
          duration: 1.1,
        })
          .from(
            '.titleDecor',
            {
              opacity: 0,
              scale: 0,
              rotation: -60,
              duration: 0.7,
              ease: 'back.out(2.5)',
            },
            '-=0.9'
          )
          .from(
            '.postTitle::after',
            {
              scaleX: 0,
              transformOrigin: 'left',
              duration: 0.6,
              ease: 'power3.out',
            },
            '-=0.4'
          )
          .from(
            '[data-post-meta]',
            {
              opacity: 0,
              y: 30,
              duration: 0.7,
              stagger: 0.12,
            },
            '-=0.4'
          )
          .from(
            '[data-post-content]',
            {
              opacity: 0,
              y: 24,
              duration: 0.8,
            },
            '-=0.3'
          );

        // Scroll-triggered animations for prose headings
        if (typeof ScrollTrigger !== 'undefined') {
          gsap.registerPlugin(ScrollTrigger);
          gsap.utils.toArray('.prose h2, .prose h3').forEach(function (el) {
            gsap.from(el, {
              scrollTrigger: {
                trigger: el,
                start: 'top 88%',
              },
              opacity: 0,
              x: -20,
              duration: 0.6,
              ease: 'power3.out',
            });
          });
        }
      });
    </script>
  </body>
</html>

<style>
  .backLink {
    position: fixed;
    top: 2rem;
    left: 2rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-secondary);
    text-decoration: none;
    font-weight: 900;
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    z-index: var(--z-ui);
    transition: transform var(--transition-speed) var(--ease-elastic);
  }

  .backLink:hover {
    transform: translateX(-6px) scale(1.08);
  }

  .backArrow {
    display: inline-block;
    transition: transform 0.3s var(--ease-elastic);
  }

  .backLink:hover .backArrow {
    transform: translateX(-5px);
  }

  .postContainer {
    max-width: 800px;
    margin: 0 auto;
    padding: 7rem 2rem 8rem;
  }

  .postHeader {
    position: relative;
    margin-bottom: 2.5rem;
  }

  .titleDecor {
    position: absolute;
    top: -2rem;
    left: -2rem;
    pointer-events: none;
    z-index: -1;
  }

  .inkBlob {
    display: block;
    width: 140px;
    height: 140px;
    background: var(--color-primary);
    clip-path: polygon(
      47% 0%,
      79% 7%,
      100% 35%,
      92% 68%,
      68% 93%,
      30% 100%,
      5% 78%,
      0% 40%,
      18% 12%
    );
    opacity: 0.1;
    transform: rotate(15deg);
  }

  .inkDot {
    display: block;
    width: 20px;
    height: 20px;
    background: var(--color-secondary);
    border-radius: 50%;
    position: absolute;
    bottom: -10px;
    right: 20px;
    opacity: 0.5;
  }

  .postTitle {
    font-size: clamp(2.2rem, 6.5vw, 5.5rem);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: var(--color-text);
    word-break: break-word;
  }

  .postTitle::after {
    content: '';
    display: block;
    width: 3.5rem;
    height: 5px;
    background: var(--color-primary);
    margin-top: 1rem;
    transform: skewX(-18deg);
  }

  .postDate {
    display: block;
    margin-top: 1.4rem;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    opacity: 0.75;
  }

  .metaSection:empty {
    display: none;
  }

  .metaSection {
    margin-bottom: 3.5rem;
  }

  /* ─── Prose: styles for MDX slot content ─── */
  .prose {
    line-height: 1.9;
    font-size: 1.05rem;
    color: rgba(248, 250, 252, 0.88);
  }

  .prose :global(h2) {
    font-size: clamp(1.3rem, 2.8vw, 1.7rem);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    border-left: 5px solid var(--color-primary);
    padding-left: 1rem;
    margin: 3.5rem 0 1.2rem;
    line-height: 1.2;
    color: var(--color-text);
  }

  .prose :global(h3) {
    font-size: 1.05rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin: 2.2rem 0 0.8rem;
  }

  .prose :global(p) {
    margin-bottom: 1.6rem;
  }

  .prose :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 4px;
    font-weight: 600;
    transition:
      color 0.2s,
      text-shadow 0.2s;
  }

  .prose :global(a:hover) {
    color: var(--color-accent);
    text-shadow: 0 0 14px var(--color-accent);
  }

  .prose :global(blockquote) {
    border-left: 5px solid var(--color-secondary);
    margin: 2.5rem 0;
    padding: 1rem 1.6rem;
    background: rgba(255, 0, 122, 0.06);
    font-style: italic;
    color: rgba(248, 250, 252, 0.7);
    position: relative;
  }

  .prose :global(blockquote::before) {
    content: '"';
    position: absolute;
    top: -0.5rem;
    left: 1rem;
    font-size: 3rem;
    color: var(--color-secondary);
    opacity: 0.3;
    font-style: normal;
    line-height: 1;
  }

  .prose :global(code) {
    font-family: 'Fira Code', 'Cascadia Code', 'JetBrains Mono', monospace;
    color: var(--color-accent);
    background: rgba(0, 240, 255, 0.08);
    padding: 0.1em 0.45em;
    border-radius: 2px;
    font-size: 0.88em;
  }

  .prose :global(pre) {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(204, 255, 0, 0.15);
    border-left: 4px solid var(--color-primary);
    padding: 1.5rem 1.8rem;
    overflow-x: auto;
    margin: 2.2rem 0;
    border-radius: 0 4px 4px 0;
    position: relative;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    color: var(--color-text);
    font-size: 0.88rem;
    line-height: 1.7;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.6rem;
    margin-bottom: 1.6rem;
  }

  .prose :global(li) {
    margin-bottom: 0.6rem;
  }

  .prose :global(li strong),
  .prose :global(strong) {
    color: var(--color-primary);
    font-weight: 700;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid rgba(204, 255, 0, 0.18);
    margin: 3.5rem 0;
  }

  .prose :global(img) {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 2rem auto;
  }
</style>
