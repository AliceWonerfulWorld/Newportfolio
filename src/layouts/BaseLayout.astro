---
/* src/layouts/BaseLayout.astro */
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import CustomCursor from '../components/islands/CustomCursor';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Portfolio</title>
		<!-- View Transitions router — ページ遷移をクライアントサイドで管理 -->
		<ClientRouter />
	</head>
	<body>
		<!-- カスタムカーソル: SSR 不可のため client:only / transition:persist で全遷移を通じて生存 -->
		<CustomCursor client:only="react" transition:persist />

		<main>
			<slot />
		</main>

		<script>
			import { gsap } from 'gsap';
			import { ScrollTrigger } from 'gsap/ScrollTrigger';

			gsap.registerPlugin(ScrollTrigger);

			// View Transitions 後に ScrollTrigger を再初期化
			document.addEventListener('astro:page-load', () => {
				ScrollTrigger.refresh();
			});
		</script>
	</body>
</html>
